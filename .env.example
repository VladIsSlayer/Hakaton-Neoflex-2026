# -----------------------------------------------------------------------------
# МИНИМУМ для запуска API (без этого `go run ./cmd/server` завершится с ошибкой)
# -----------------------------------------------------------------------------
DATABASE_URL=
JWT_SECRET=

# -----------------------------------------------------------------------------
# Минимум для фронта с каталогом через Supabase (PostgREST из браузера)
# Если пусто — часть экранов без данных из Supabase; API через /api всё равно работает.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
# Любой из двух (см. vite.config): публикуемый/anon ключ проекта Supabase
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# -----------------------------------------------------------------------------
# Ниже — необязательно; значения подходят для локальной разработки
# -----------------------------------------------------------------------------
APP_ENV=development
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

WEBHOOK_GIT_SECRET=
JUDGE0_BASE_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=

# UUID курса для админ-статистики (возьмите из своей БД после сидов)
STATS_COURSE_ID=

DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=1m

# В dev оставьте пустым — Vite проксирует /api на localhost:8080
VITE_API_URL=
# VITE_DEV_API_PROXY=http://localhost:8080
# VITE_FREE_COURSE_ID=

# SEED_IF_EMPTY=0
# SEED_JSON_PATH=data/seed.json
# MIGRATIONS_DIR=../../infra/postgres/migrations
