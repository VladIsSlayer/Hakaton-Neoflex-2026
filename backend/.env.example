APP_ENV=development
PORT=8080
# Разрешённые origin для CORS (один или несколько через запятую). В development к localhost/127.0.0.1 добавляются зеркала.
FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# Supabase Session Pooler URL (recommended on IPv4 networks)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# Required for token signing
JWT_SECRET=replace-with-long-random-secret-32-plus-chars

# Required in production for webhook verification
WEBHOOK_GIT_SECRET=replace-with-webhook-secret

# Judge0 (optional)
JUDGE0_BASE_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=

# Admin stats default course
STATS_COURSE_ID=7dabf3fa-15d8-4a5d-bcf6-9cc188a7c074

# Если нет опубликованных курсов — при старте залить Postgres из JSON (в development по умолчанию включено)
# SEED_IF_EMPTY=0
# SEED_JSON_PATH=data/seed.json

# Фронт (корневой .env): опционально UUID бесплатного курса для лендинга и демо-контента урока
# VITE_FREE_COURSE_ID=7dabf3fa-15d8-4a5d-bcf6-9cc188a7c074

# pgx pool tuning
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=1m
